{
  "version": "0.2.0",
  "configurations": [
    {
      // Open terminal and move to frontend folder. Run: "yarn dev". Finally launch the debugger
      // Usually the portal should not be hardcoded but we use it locally here
      "name": "Frontend (Chrome, Next.js)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend",
      "urlFilter": "http://localhost:3000/*",
      "skipFiles": ["**/node_modules/**", "<node_internals>/**"],
      "sourceMapPathOverrides": {
        "webpack://_N_E/./*": "${webRoot}/*",
        "webpack:///./*": "${webRoot}/*",
        "webpack:///*": "${webRoot}/*",
        "webpack:///src/*": "${webRoot}/src/*"
      }
    },
    {
      // Just launch the vs code Debugger and the terminal will move to backend folder and attach the debugger
      "name": "Backend (Node via yarn dev)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "autoAttachChildProcesses": true,
      "env": { "NODE_OPTIONS": "--inspect" }
    }
  ],
  "compounds": [
    {
      "name": "Run Both (attach Chrome)",
      "configurations": [
        "Backend (Node via yarn dev)",
        "Frontend (Chrome, Next.js)"
      ]
    }
  ]
}
