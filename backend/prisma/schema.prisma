generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/database/database.db"
}

model Host {
  id                Int             @id @default(autoincrement())
  name              String          @unique
  municipalityId    Int
  domain            String?
  idpId             Int
  idp               IDP             @relation(fields: [idpId], references: [id] )
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model IDP {
  id                Int             @id @default(autoincrement())
  name              String?
  entryPoint        String
  idpCert           String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  hosts             Host[]
}